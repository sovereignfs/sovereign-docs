{
  "schemaVersion": 1,
  "id": "fs.sovereign.docs",
  "name": "Docs",
  "version": "0.1.0",
  "description": "A git-backed document workspace.",
  "type": "sovereign",
  "runtime": "native",
  "routePrefix": "/docs",
  "shell": "default",
  "database": {
    "isolation": "isolated",
    "dialect": "sqlite"
  },
  "icon": "icon.svg",
  "permissions": [
    "auth:session",
    "db:readWrite",
    "mailer:send",
    "notifications:send",
    "data:provide",
    "data:export",
    "data:import"
  ],
  "repository": "https://github.com/sovereignfs/sovereign-docs",
  "compatibility": {
    "minPlatformVersion": "0.19.0"
  }
}
