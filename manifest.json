{
  "schemaVersion": 1,
  "id": "fs.sovereign.docs",
  "name": "Docs",
  "version": "0.2.0",
  "description": "A local-first document workspace with optional git sync.",
  "development": true,
  "type": "sovereign",
  "runtime": "native",
  "routePrefix": "/docs",
  "shell": "default",
  "database": {
    "isolation": "isolated",
    "dialect": "sqlite"
  },
  "icon": "icon.svg",
  "permissions": [
    "auth:session",
    "db:readWrite",
    "mailer:send",
    "notifications:send",
    "data:provide",
    "data:export",
    "data:import"
  ],
  "env": {
    "FREE_DOC_LIMIT": {
      "description": "Maximum number of local (non-git) documents a user may create before a Sovereign Drive (git repo) must be connected. Integer > 0.",
      "required": false,
      "scope": "runtime",
      "default": "25"
    }
  },
  "repository": "https://github.com/sovereignfs/sovereign-docs",
  "compatibility": {
    "minPlatformVersion": "0.19.0"
  }
}
